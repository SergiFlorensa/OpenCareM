# App
APP_NAME=Task Manager API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-in-real-environments
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (local default: SQLite)
DATABASE_URL=sqlite:///./task_manager.db
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (JSON list for pydantic-settings)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:8000","http://localhost:8080"]

# Logging
LOG_LEVEL=INFO

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Clinical chat trust policy
CLINICAL_CHAT_WEB_ENABLED=true
CLINICAL_CHAT_WEB_TIMEOUT_SECONDS=6
CLINICAL_CHAT_WEB_STRICT_WHITELIST=true
CLINICAL_CHAT_WEB_ALLOWED_DOMAINS=who.int,cdc.gov,nih.gov,pubmed.ncbi.nlm.nih.gov,scielo.org,nejm.org,thelancet.com,bmj.com,jamanetwork.com,seimc.org,semicyuc.org,semes.org,guiasalud.es,openevidence.com
CLINICAL_CHAT_WEB_LINK_ANALYSIS_ENABLED=true
CLINICAL_CHAT_WEB_LINK_ANALYSIS_PATH=docs/web_raw/link_analysis_snapshot.json
CLINICAL_CHAT_WEB_LINK_ANALYSIS_BLEND=0.35
CLINICAL_CHAT_WEB_LINK_ANALYSIS_MAX_HITS_BASE=120
CLINICAL_CHAT_PDF_PARSER_BACKEND=pypdf
CLINICAL_CHAT_PDF_MINERU_BASE_URL=http://127.0.0.1:8091
CLINICAL_CHAT_PDF_MINERU_TIMEOUT_SECONDS=90
CLINICAL_CHAT_PDF_MINERU_FAIL_OPEN=true
CLINICAL_CHAT_PDF_OCR_MODE=region_selective
